{
  "name": "dining-ops-platform",
  "private": true,
  "version": "0.1.0",
  "description": "餐饮连锁运营平台 · Dining Ops Platform",
  "author": "Dining Ops Platform",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:electron": "cross-env ELECTRON=true vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"cross-env ELECTRON=true vite --port 5173 --strictPort\" \"wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build:electron && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder",
    "electron:pack": "npm run build:electron && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --dir",
    "lint": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{vue,js,json,css,scss}\""
  },
  "dependencies": {
    "@antv/x6": "^3.1.7",
    "@element-plus/icons-vue": "2.3.2",
    "cesium": "^1.142.0",
    "d3": "^7.9.0",
    "echarts": "^6.1.0",
    "element-plus": "^2.9.7",
    "mqtt": "^5.15.1",
    "pinia": "^3.0.1",
    "pinia-plugin-persistedstate": "^4.7.1",
    "three": "^0.184.0",
    "vite-plugin-cesium": "^1.2.23",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "eslint": "^9.22.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "sass": "^1.85.1",
    "unplugin-auto-import": "^19.1.1",
    "unplugin-vue-components": "^28.4.1",
    "vite": "^6.2.2",
    "vite-plugin-vue-devtools": "^8.1.3",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.diningops.platform",
    "productName": "Dining Ops Platform",
    "copyright": "Copyright © 2026 Dining Ops Platform",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
